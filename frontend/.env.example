# Public base URL of the FastAPI backend (exposed to the browser at build time).
# Local dev:   http://localhost:8000/api/v1
# Production:  https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Optional: server-side base URL used by React Server Components when it should
# differ from the public one (e.g. an internal network address). Falls back to
# NEXT_PUBLIC_API_BASE_URL when unset.
# API_BASE_URL=http://backend:8000/api/v1

# Public URL of the site itself — used for SEO: canonical URLs, sitemap.xml,
# robots.txt, Open Graph tags and JSON-LD. Set this in production.
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
